// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id         String      @id @default(uuid())
  nome       String
  email      String      @unique
  senha      String
  telefone   String?
  status     String      @default("ENABLED")
  aluno      Aluno?
  professor  Professor?
  userPerfis UserPerfil[]
}

model Perfil {
  id               String             @id @default(uuid())
  nome             String
  descricao        String
  created_at       DateTime           @default(now())
  updated_at       DateTime           @updatedAt
  userPerfis       UserPerfil[]
  perfilPermissions PerfilPermission[]
}

model Permission {
  id                String             @id @default(uuid())
  codigo            String             @unique
  descricao         String
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt
  perfilPermissions PerfilPermission[]
}

model UserPerfil {
  usuario_id String
  perfil_id  String
  usuario    Usuario @relation(fields: [usuario_id], references: [id])
  perfil     Perfil  @relation(fields: [perfil_id], references: [id])

  @@id([usuario_id, perfil_id])
}

model PerfilPermission {
  perfil_id     String
  permission_id String
  perfil        Perfil     @relation(fields: [perfil_id], references: [id])
  permission    Permission @relation(fields: [permission_id], references: [id])

  @@id([perfil_id, permission_id])
}

model Aluno {
  id               String           @id @default(uuid())
  frequencia_atual Int              @default(0)
  grau_faixa       Int              @default(0)
  faixa            String           @default("BRANCA")
  usuarioId        String           @unique
  usuario          Usuario          @relation(fields: [usuarioId], references: [id])
  frequencias      FrequenciaAluno[]
  alunoTurmas      AlunoTurma[]
  notificacoes     Notificacao[]
}

model Professor {
  id                         String           @id @default(uuid())
  faixa                      String           @default("BRANCA")
  grau                       Int              @default(0)
  usuarioId                  String           @unique
  usuario                    Usuario          @relation(fields: [usuarioId], references: [id])
  frequenciasAlunoRegistradas FrequenciaAluno[]
  professorTurmas            ProfessorTurma[]
  frequenciasProfessor       FrequenciaProf[]
  notificacoes               Notificacao[]
}

model Turma {
  id             String           @id @default(uuid())
  nome           String
  horario_inicio DateTime
  horario_fim    DateTime
  data_especifica DateTime?
  segunda        Boolean          @default(false)
  terca          Boolean          @default(false)
  quarta         Boolean          @default(false)
  quinta         Boolean          @default(false)
  sexta          Boolean          @default(false)
  sabado         Boolean          @default(false)
  domingo        Boolean          @default(false)
  frequenciasAluno FrequenciaAluno[]
  alunoTurmas    AlunoTurma[]
  professorTurmas ProfessorTurma[]
  frequenciasProfessor FrequenciaProf[]

  @@map("turma")
}

model FrequenciaAluno {
  id            String         @id @default(uuid())
  aluno_id      String
  professor_id  String
  turma_id      String
  data          DateTime
  horario_inicio DateTime
  horario_fim   DateTime
  status_presenca String
  aluno         Aluno          @relation(fields: [aluno_id], references: [id])
  professor     Professor      @relation(fields: [professor_id], references: [id])
  turma         Turma          @relation(fields: [turma_id], references: [id])

  @@index([aluno_id])
  @@index([professor_id])
  @@index([turma_id])
  @@map("frequencia_aluno")
}

model AlunoTurma {
  aluno_id   String
  turma_id   String
  frequente  String          @default("N")
  aluno      Aluno           @relation(fields: [aluno_id], references: [id])
  turma      Turma           @relation(fields: [turma_id], references: [id])

  @@id([aluno_id, turma_id])
  @@index([turma_id])
  @@map("aluno_turma")
}

model ProfessorTurma {
  professor_id String
  turma_id     String
  professor    Professor      @relation(fields: [professor_id], references: [id])
  turma        Turma          @relation(fields: [turma_id], references: [id])

  @@id([professor_id, turma_id])
  @@index([turma_id])
  @@map("professor_turma")
}

model FrequenciaProf {
  id            String       @id @default(uuid())
  data          DateTime
  professor_id  String
  turma_id      String
  status_aula   String
  data_remarcacao DateTime?
  professor     Professor    @relation(fields: [professor_id], references: [id])
  turma         Turma        @relation(fields: [turma_id], references: [id])

  @@index([professor_id])
  @@index([turma_id])
  @@map("frequencia_prof")
}

model Notificacao {
  id           String    @id @default(uuid())
  professor_id String
  aluno_id     String
  mensagem     String
  lida         Boolean   @default(false)
  created_at   DateTime  @default(now())
  professor    Professor @relation(fields: [professor_id], references: [id])
  aluno        Aluno     @relation(fields: [aluno_id], references: [id])

  @@index([professor_id])
  @@map("notificacao")
}

