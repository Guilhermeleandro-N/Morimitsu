{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "start-nestjs-dev",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "start:dev"
      ],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[Nest\\]",
          "endsPattern": "Nest application successfully started|ERROR|listening on"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "terminate-nestjs",
      "type": "shell",
      "command": "pkill",
      "args": [
        "-f",
        "node.*start:dev|nest start --debug"
      ],
      "isBackground": false,
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}